{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "out",
    "baseUrl": "../../",
    "paths": {
      "@coding-bubble/backend": ["packages/backend/src/index.ts"],
      "@coding-bubble/shared": ["packages/shared/src/index.ts"],
      "@coding-bubble/session-monitor": ["packages/session-monitor/src/index.ts"],
      "@coding-bubble/stream-json": ["packages/stream-json/src/index.ts"],
      "@coding-bubble/remote": ["packages/remote/src/client/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true
  },
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*"
  ]
}
