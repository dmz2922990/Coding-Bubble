{
  "name": "coding-bubble",
  "version": "0.1.2",
  "private": true,
  "description": "A lightweight desktop AI companion living as a floating ball on your screen. Supports macOS & Windows.",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter @coding-bubble/desktop run dev",
    "build": "pnpm --filter @coding-bubble/desktop run build",
    "package": "pnpm --filter @coding-bubble/desktop run package",
    "test": "vitest run",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "vitest": "^2"
  }
}
